{
  "name": "claude-link",
  "version": "0.0.1",
  "description": "P2P bridge between two Claude Code sessions over WebRTC",
  "type": "module",
  "main": "src/cli.ts",
  "bin": {
    "claude-link": "src/cli.ts"
  },
  "files": [
    "src",
    "install.sh",
    "install.ps1",
    "uninstall.sh",
    "uninstall.ps1",
    "README.md",
    "LICENSE",
    "PROJECT-STRUCTURE.md"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "e2e:peer": "bun run scripts/e2e-peer.ts",
    "e2e:mcp": "bun run scripts/e2e-mcp.ts",
    "smoke:paths": "bun run scripts/smoke-paths.ts",
    "id": "bun run src/cli.ts id",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/cli.ts --outfile dist/claude-link.js --target=bun --minify"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@msgpack/msgpack": "^2.8.0",
    "eventemitter3": "^4.0.7",
    "node-datachannel": "^0.32.3",
    "peerjs-js-binarypack": "^2.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "typescript": "^5.0.0"
  },
  "trustedDependencies": [
    "node-datachannel"
  ]
}
