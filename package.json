{
  "name": "claude-link",
  "version": "0.0.11",
  "description": "P2P bridge between two Claude Code sessions over WebRTC",
  "type": "module",
  "main": "dist/launcher.cjs",
  "bin": {
    "claude-link-mcp": "src/bin/mcp.ts",
    "claude-link-config": "src/bin/config.ts",
    "claude-link-id": "src/bin/id.ts"
  },
  "files": [
    "src",
    "dist",
    "skills",
    "install.sh",
    "install.ps1",
    "uninstall.sh",
    "uninstall.ps1",
    "README.md",
    "LICENSE",
    "PROJECT-STRUCTURE.md"
  ],
  "scripts": {
    "dev": "node dist/launcher.cjs",
    "e2e:peer": "bun run scripts/e2e-peer.ts",
    "e2e:mcp": "bun run scripts/e2e-mcp.ts",
    "e2e:inject": "bun run scripts/e2e-inject.ts",
    "smoke:paths": "bun run scripts/smoke-paths.ts",
    "id": "bun run src/bin/id.ts",
    "config": "bun run src/bin/config.ts",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@msgpack/msgpack": "^2.8.0",
    "eventemitter3": "^4.0.7",
    "node-datachannel": "^0.32.3",
    "node-pty": "^1.1.0",
    "peerjs-js-binarypack": "^2.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "typescript": "^5.0.0"
  },
  "trustedDependencies": [
    "node-datachannel",
    "node-pty"
  ]
}
